parameters:
    level: 8
    paths:
        - src
        - tests
    excludePaths:
        - demo/*
        - vendor/*
    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false
    ignoreErrors:
        -
            identifier: return.unusedType
            path: tests/Unit/Envelope/EnvelopeBuilderTest.php

{% extends 'base.html.twig' %}
{% block title %}Beacon Bundle demo{% endblock %}
{% block body %}
<div class="container py-5">
    <h1 class="mb-3">Beacon Bundle demo</h1>
    <p class="lead">Report events to any Symfony Beacon instance via <code>BEACON_DSN</code> and exercise the main success and failure scenarios.</p>
    <ul>
        <li><a href="{{ path('demo_report') }}">GET /report</a> - capture an <code>info</code> message</li>
        <li><a href="{{ path('demo_report_error') }}">GET /report-error</a> - capture an <code>error</code> message</li>
        <li><a href="{{ path('demo_exception') }}">GET /exception</a> - capture a manual exception and show its event id</li>
        <li><a href="{{ path('demo_boom') }}">GET /boom</a> - throw a <code>RuntimeException</code> for the listener</li>
        <li><a href="{{ path('demo_boom_ignored') }}">GET /boom-ignored</a> - throw an ignored <code>InvalidArgumentException</code></li>
        <li><a href="{{ path('demo_fingerprint') }}">GET /fingerprint</a> - capture a message with a custom fingerprint</li>
        <li><a href="{{ path('demo_status') }}">GET /status</a> - JSON status for <code>enabled</code>, <code>has_dsn</code>, and <code>environment</code></li>
    </ul>
    <p class="text-muted small mb-0">Set <code>BEACON_DSN=https://PUBLIC@host:port/PROJECT_ID</code> in <code>.env</code>. Leave it empty to disable reporting. For local self-signed HTTPS Beacon servers, set <code>verify_peer: false</code> in <code>when@dev</code> only.</p>
</div>
{% endblock %}

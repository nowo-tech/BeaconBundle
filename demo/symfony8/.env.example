# APP_ENV: Symfony environment (dev/test/prod). In demos it is usually `dev`.
APP_ENV=dev

# APP_DEBUG: Enable/disable detailed debug output (usually `1` in dev).
APP_DEBUG=1

# APP_SECRET: Secret used for signing/tokens. Use a local-only value in demos.
APP_SECRET=CHANGE_ME_LOCAL_SECRET

# PORT: Host port mapped to HTTP :80 inside the FrankenPHP container (symfony8 demo default: 8011).
PORT=8011

# DEFAULT_URI: Base URL for generating URLs in CLI (must match PORT for local HTTP checks).
DEFAULT_URI=http://localhost:8011

# BEACON_DSN: Symfony Beacon ingest DSN (empty = disabled).
# Secret REQUIRED: scheme://PUBLIC:SECRET@host:port/PROJECT_ID
# From this FrankenPHP container use host.docker.internal (see docker-compose extra_hosts).
# Prefer HTTP :9081 — Beacon serves /api/* on HTTP for Docker clients; browsers use HTTPS :9444.
# After `make bootstrap` in symfony-beacon, run `make sync-beacon` here (or `make up`, which syncs automatically).
# File source: ../../../../other/symfony-beacon/.demo-client.env (override with BEACON_REPO=...).
# Auth: X-Beacon-Auth with beacon_key + beacon_secret (BeaconBundle ≥ 1.5 / symfony-beacon ≥ 0.9).
BEACON_DSN=

# BEACON_RELEASE: optional release/version tag attached to events when send.release is true.
BEACON_RELEASE=demo-symfony8@dev

{% extends 'base.html.twig' %}
{% block title %}{{ heading }}{% endblock %}
{% block body %}
<h1>{{ heading }}</h1>
<p>{{ description }}</p>
<p>Client enabled: <strong>{{ enabled ? 'yes' : 'no' }}</strong></p>
<p>Level: <code>{{ level }}</code></p>
<p>Event id: <code>{{ eventId ?? 'null (DSN empty or disabled)' }}</code></p>
{% if fingerprint is not empty %}
    <p>Fingerprint: <code>{{ fingerprint|join(', ') }}</code></p>
{% endif %}
<p class="text-muted small">Event ids are generated locally. For TLS failures or rejected keys, verify the result in Beacon or in the application logs.</p>
<p><a href="{{ path('homepage') }}">Home</a> · <a href="{{ path('demo_status') }}">Status JSON</a></p>
{% endblock %}
